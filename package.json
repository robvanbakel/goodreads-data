{
  "name": "goodreads-data",
  "version": "1.0.2",
  "description": "Fetch and parse public Goodreads shelf data",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "goodreads",
    "books",
    "shelves",
    "rss"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robvanbakel/goodreads-data.git"
  },
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "^5.5.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
